{
  "name": "bolha-politica",
  "version": "1.0.2",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "npx prettier --write 'src/**/*.{ts,html,css}'",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run lint && esbuild src/background.ts src/popup.ts src/content.ts --bundle --format=iife --target=safari16,chrome110 --outdir=dist --platform=browser && cp manifest.json src/popup.html src/popup.css src/content.css dist/ && cp -R assets dist/",
    "watch": "esbuild src/background.ts src/popup.ts src/content.ts --bundle --format=iife --target=safari16,chrome110 --outdir=dist --platform=browser --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "esbuild": "^0.27.4",
    "fake-indexeddb": "^6.2.5",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  }
}
